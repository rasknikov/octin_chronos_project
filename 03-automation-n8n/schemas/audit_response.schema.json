{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["allow", "issues", "severity"],
  "properties": {
    "allow": {"type": "boolean"},
    "issues": {"type": "array", "items": {"type": "string"}},
    "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]}
  }
}
